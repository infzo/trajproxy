# ============================================================
# TrajProxy 可观测性组件 - 环境变量模板（提交到仓库）
# ============================================================
# 使用方式：cp .env.example .env  然后按需修改

# Prometheus 通过 host.docker.internal 抓取宿主机上的业务服务
# （见 configs/prometheus/prometheus.yml）

# --- 端口配置 ---
# 注意：Docker Desktop 会占用 9090，所以 Prometheus 默认使用 19090
PROMETHEUS_PORT=19090
GRAFANA_PORT=3000
ALERTMANAGER_PORT=9093
VIEWER_PORT=8081

# --- Grafana 账号 ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=trajproxy

# --- TrajProxy Worker 端口范围 ---
# 每个监控节点会展开为 [WORKER_PORT_START, WORKER_PORT_START+WORKER_PORT_COUNT)
WORKER_PORT_START=12300
WORKER_PORT_COUNT=10

# --- 监控节点 ---
# IP 列表，空格分隔。启动脚本会根据 WORKER_PORT_START/COUNT 展开为 Prometheus targets。
# 格式: "192.168.1.100 192.168.1.101 10.0.0.5"
# 留空或注释掉则不生成任何业务 target。
# 也可在 CLI 用 start <ip1> <ip2> 临时覆盖（不写回本文件）。
MONITOR_NODES="localhost"

# --- Prometheus 数据保留 ---
PROMETHEUS_RETENTION=30d
PROMETHEUS_RETENTION_SIZE=50GB

# --- 告警通知方式（填入后生效）---
# WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx
# WEBHOOK_SECRET=your_secret_here

# --- 本地容器内通信使用的主机标识 ---
# Prometheus 跑在 docker 里，访问宿主机用 host.docker.internal
PROMETHEUS_TARGET_HOST=host.docker.internal
