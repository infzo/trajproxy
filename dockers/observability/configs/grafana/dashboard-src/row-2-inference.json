[
  {
    "type": "row",
    "title": "Row 2 — 推理请求",
    "gridPos": {
      "h": 1,
      "w": 24,
      "x": 0,
      "y": 20
    },
    "collapsed": false
  },
  {
    "id": 11,
    "type": "timeseries",
    "title": "推理请求数 (5min) - 按运行标识",
    "description": "各作业每 5 分钟请求数量趋势",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 0,
      "y": 21
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum by (run_id) (increase(trajproxy_requests_total{node=~\"$node\",run_id=~\"$run_id\"}[5m]))",
        "legendFormat": "{{ run_id }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "custom": {
          "fillOpacity": 25,
          "stacking": {
            "mode": "normal"
          },
          "drawStyle": "line"
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "mean"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 12,
    "type": "timeseries",
    "title": "推理请求数 (5min) - 按结果",
    "description": "每 5 分钟请求数量按结果分类",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 6,
      "y": 21
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum by (outcome) (increase(trajproxy_requests_total{node=~\"$node\",model=~\"$model\"}[5m]))",
        "legendFormat": "{{ outcome }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "custom": {
          "fillOpacity": 20,
          "drawStyle": "line"
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "sum"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 50,
    "type": "timeseries",
    "title": "推理请求端到端耗时 - 按运行标识 (q=$quantile)",
    "description": "端到端请求延迟 q=$quantile 分位（含全 Pipeline），按 run_id 分组",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 0,
      "y": 29
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "histogram_quantile($quantile, sum by (le, run_id) (rate(trajproxy_request_duration_seconds_bucket{node=~\"$node\",model=~\"$model\",run_id=~\"$run_id\"}[5m])))",
        "legendFormat": "{{ run_id }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "s",
        "decimals": 2,
        "custom": {
          "fillOpacity": 5,
          "drawStyle": "line",
          "spanNulls": true
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "mean",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 51,
    "type": "timeseries",
    "title": "推理服务调用耗时 - 按运行标识 (q=$quantile)",
    "description": "对下游推理服务的单次 HTTP 调用耗时 q=$quantile 分位（取 phase=inference），按 run_id 分组",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 6,
      "y": 29
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "histogram_quantile($quantile, sum by (le, run_id) (rate(trajproxy_phase_duration_seconds_bucket{node=~\"$node\",phase=\"inference\",run_id=~\"$run_id\"}[5m])))",
        "legendFormat": "{{ run_id }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "s",
        "decimals": 2,
        "custom": {
          "fillOpacity": 5,
          "drawStyle": "line"
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "mean",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 52,
    "type": "timeseries",
    "title": "推理首 Token 耗时 (TTFT) - 按运行标识 (q=$quantile)",
    "description": "流式请求首 Token 耗时 q=$quantile 分位，按 run_id 分组",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 12,
      "y": 29
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "histogram_quantile($quantile, sum by (le, run_id) (rate(trajproxy_ttft_seconds_bucket{node=~\"$node\",run_id=~\"$run_id\"}[5m])))",
        "legendFormat": "{{ run_id }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "s",
        "decimals": 2,
        "custom": {
          "fillOpacity": 10,
          "drawStyle": "line"
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "mean",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 53,
    "type": "timeseries",
    "title": "推理序列长度（输入+输出） - 按运行标识 (q=$quantile)",
    "description": "每请求总序列长度 $quantile:text 分位（prompt + completion tokens），按 run_id 分组",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 18,
      "y": 29
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "histogram_quantile($quantile, sum by (le, run_id) (rate(trajproxy_sequence_length_tokens_bucket{node=~\"$node\",model=~\"$model\",run_id=~\"$run_id\"}[5m])))",
        "legendFormat": "{{ run_id }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "decimals": 0,
        "custom": {
          "fillOpacity": 10,
          "drawStyle": "line"
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "mean",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 22,
    "type": "timeseries",
    "title": "推理 Pipeline 各阶段耗时",
    "description": "识别瓶颈阶段",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 12,
      "y": 21
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "histogram_quantile(0.95, sum by (le, phase) (rate(trajproxy_phase_duration_seconds_bucket{node=~\"$node\",model=~\"$model\"}[5m])))",
        "legendFormat": "{{ phase }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "s",
        "decimals": 2,
        "custom": {
          "fillOpacity": 10,
          "drawStyle": "line"
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "mean",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 13,
    "type": "piechart",
    "title": "推理流式与非流式占比",
    "description": "流式请求占比",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 18,
      "y": 21
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum by (stream) (increase(trajproxy_requests_total{node=~\"$node\",model=~\"$model\"}[1h]))",
        "legendFormat": "{{ stream }}",
        "refId": "A",
        "instant": true
      }
    ],
    "options": {
      "pieType": "donut",
      "displayLabels": [
        "percent"
      ],
      "legend": {
        "displayMode": "list",
        "placement": "right"
      }
    }
  },
  {
    "id": 140,
    "type": "timeseries",
    "title": "推理请求失败数量 - 按运行标识 (5min)",
    "description": "推理请求失败按运行标识聚合统计：左轴为请求级失败总数，右轴为轨迹写入 DB 失败数",
    "gridPos": {
      "h": 10,
      "w": 12,
      "x": 0,
      "y": 37
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "custom": {
          "fillOpacity": 10,
          "drawStyle": "line",
          "lineWidth": 2,
          "pointSize": 5,
          "showPoints": "auto",
          "spanNulls": false
        }
      },
      "overrides": [
        {
          "matcher": {
            "id": "byRegexp",
            "options": "^写入.*"
          },
          "properties": [
            {
              "id": "custom.axisPlacement",
              "value": "right"
            },
            {
              "id": "color",
              "value": {
                "mode": "palette-classic"
              }
            }
          ]
        }
      ]
    },
    "targets": [
      {
        "expr": "sum by (run_id) (increase(trajproxy_requests_total{node=~\"$node\",run_id=~\"$run_id\",outcome=~\"error_infer|timeout|stream_partial|error_server\"}[5m]))",
        "legendFormat": "失败: {{ run_id }}",
        "refId": "A"
      },
      {
        "expr": "sum by (run_id) (increase(trajproxy_trajectory_store_errors_total{node=~\"$node\",run_id=~\"$run_id\"}[5m]))",
        "legendFormat": "写入: {{ run_id }}",
        "refId": "B"
      }
    ],
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "sum",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 141,
    "type": "timeseries",
    "title": "推理请求错误细分（请选择 Run ID）",
    "description": "展示所选 run_id 的推理错误按错误子类型（connect_timeout / read_timeout / connection / rate_limited / http_error / unknown）拆分的时间分布。需先在顶端 Run ID 下拉框选择具体标识，选 All 时为所有标识的聚合。",
    "gridPos": {
      "h": 10,
      "w": 12,
      "x": 12,
      "y": 37
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "custom": {
          "fillOpacity": 50,
          "stacking": {
            "mode": "normal"
          },
          "drawStyle": "bars"
        }
      },
      "overrides": [
        {
          "matcher": { "id": "byName", "options": "connect_timeout" },
          "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }]
        },
        {
          "matcher": { "id": "byName", "options": "read_timeout" },
          "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }]
        },
        {
          "matcher": { "id": "byName", "options": "connection" },
          "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }]
        },
        {
          "matcher": { "id": "byName", "options": "rate_limited" },
          "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } }]
        },
        {
          "matcher": { "id": "byName", "options": "http_error" },
          "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }]
        },
        {
          "matcher": { "id": "byName", "options": "unknown" },
          "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "text" } }]
        }
      ]
    },
    "targets": [
      {
        "expr": "sum by (error_type) (increase(trajproxy_request_infer_errors_total{node=~\"$node\",run_id=~\"$run_id\"}[5m]))",
        "legendFormat": "{{ error_type }}",
        "refId": "A"
      }
    ],
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "sum",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  }
]
