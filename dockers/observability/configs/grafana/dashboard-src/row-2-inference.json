  {
    "id": 35,
    "type": "timeseries",
    "title": "推理并发限流 (429)",
    "description": "Semaphore 超时拒绝速率",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 18,
      "y": 29
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum by (model) (rate(trajproxy_semaphore_rejected_total{node=~\"$node\"}[5m]))",
        "legendFormat": "rejected: {{ model }}",
        "refId": "A"
      },
      {
        "expr": "histogram_quantile(0.95, sum by (le) (rate(trajproxy_semaphore_wait_seconds_bucket{node=~\"$node\"}[5m])))",
        "legendFormat": "wait P95",
        "refId": "B"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "short"
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "mean",
          "max"
        ]
      }
    }
  },
  {
    "id": 50,
    "type": "timeseries",
    "title": "推理请求端到端耗时 - 按运行标识 (q=$quantile)",
    "description": "端到端请求延迟 q=$quantile 分位（含全 Pipeline），按 run_id 分组",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 0,
      "y": 37
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "histogram_quantile($quantile, sum by (le, run_id) (rate(trajproxy_request_duration_seconds_bucket{node=~\"$node\",model=~\"$model\",run_id=~\"$run_id\"}[5m])))",
        "legendFormat": "{{ run_id }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "s",
        "decimals": 2,
        "custom": {
          "fillOpacity": 5,
          "drawStyle": "line",
          "spanNulls": true
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "mean",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 51,
    "type": "timeseries",
    "title": "推理服务调用耗时 - 按运行标识 (q=$quantile)",
    "description": "对下游推理服务的单次 HTTP 调用耗时 q=$quantile 分位（取 phase=inference），按 run_id 分组",
    "gridPos": {
      "h": 8,
