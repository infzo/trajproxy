          },
          "properties": [
            {
              "id": "color",
              "value": {
                "mode": "fixed",
                "fixedColor": "red"
              }
            },
            {
              "id": "displayName",
              "value": "无内容 (empty)"
            }
          ]
        }
      ]
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "lastNotNull",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 161,
    "type": "timeseries",
    "title": "活跃作业数量",
    "description": "有推理请求的活动作业数，反映当前同时运行的作业数",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 0,
      "y": 37
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "count(count by (run_id) (increase(trajproxy_requests_total{node=~\"$node\"}[$rate_interval]) > 0))",
        "legendFormat": "活跃作业数量",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "decimals": 0,
        "custom": {
          "fillOpacity": 20,
          "drawStyle": "line",
          "spanNulls": true
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "lastNotNull",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
