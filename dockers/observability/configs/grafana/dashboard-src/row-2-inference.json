  {
    "id": 13,
    "type": "piechart",
    "title": "推理流式与非流式占比",
    "description": "流式请求占比",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 6,
      "y": 61
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum by (stream) (increase(trajproxy_requests_total{node=~\"$node\",model=~\"$model\"}[1h]))",
        "legendFormat": "{{ stream }}",
        "refId": "A",
        "instant": true
      }
    ],
    "options": {
      "pieType": "donut",
      "displayLabels": [
        "percent"
      ],
      "legend": {
        "displayMode": "list",
        "placement": "right"
      }
    }
