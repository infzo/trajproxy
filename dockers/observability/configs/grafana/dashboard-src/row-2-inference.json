  {
    "id": 140,
    "type": "timeseries",
    "title": "жҺЁзҗҶиҜ·жұӮеӨұиҙҘж•°йҮҸ - жҢүиҝҗиЎҢж ҮиҜҶ (5min)",
    "description": "жҺЁзҗҶиҜ·жұӮеӨұиҙҘжҢүиҝҗиЎҢж ҮиҜҶиҒҡеҗҲз»ҹи®Ўпјҡе·ҰиҪҙдёәиҜ·жұӮзә§еӨұиҙҘжҖ»ж•°пјҢеҸіиҪҙдёәиҪЁиҝ№еҶҷе…Ҙ DB еӨұиҙҘж•°",
    "gridPos": {
      "h": 10,
      "w": 12,
      "x": 0,
      "y": 37
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "custom": {
          "fillOpacity": 10,
          "drawStyle": "line",
          "lineWidth": 2,
          "pointSize": 5,
          "showPoints": "auto",
          "spanNulls": false
        }
      },
      "overrides": [
        {
          "matcher": {
            "id": "byRegexp",
            "options": "^еҶҷе…Ҙ.*"
          },
          "properties": [
            {
              "id": "custom.axisPlacement",
              "value": "right"
            },
            {
              "id": "color",
              "value": {
                "mode": "palette-classic"
              }
            }
          ]
        }
      ]
    },
    "targets": [
      {
        "expr": "sum by (run_id) (increase(trajproxy_requests_total{node=~\"$node\",run_id=~\"$run_id\",outcome=~\"error_infer|timeout|stream_partial|error_server\"}[5m]))",
        "legendFormat": "еӨұиҙҘ: {{ run_id }}",
        "refId": "A"
      },
      {
        "expr": "sum by (run_id) (increase(trajproxy_trajectory_store_errors_total{node=~\"$node\",run_id=~\"$run_id\"}[5m]))",
        "legendFormat": "еҶҷе…Ҙ: {{ run_id }}",
        "refId": "B"
      }
    ],
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "sum",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 141,
    "type": "timeseries",
    "title": "жҺЁзҗҶиҜ·жұӮй”ҷиҜҜз»ҶеҲҶпјҲиҜ·йҖүжӢ© Run IDпјү",
    "description": "еұ•зӨәжүҖйҖү run_id зҡ„жҺЁзҗҶй”ҷиҜҜжҢүй”ҷиҜҜеӯҗзұ»еһӢжӢҶеҲҶзҡ„ж—¶й—ҙеҲҶеёғпјҢеҗ«дёӯж–ҮеҸӢеҘҪеҗҚз§°гҖӮйңҖе…ҲеңЁйЎ¶з«Ҝ Run ID дёӢжӢүжЎҶйҖүжӢ©е…·дҪ“ж ҮиҜҶпјҢйҖү All ж—¶дёәжүҖжңүж ҮиҜҶзҡ„иҒҡеҗҲгҖӮ",
    "gridPos": {
      "h": 10,
      "w": 12,
      "x": 12,
      "y": 37
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "custom": {
          "fillOpacity": 50,
          "stacking": {
            "mode": "normal"
          },
          "drawStyle": "bars"
        }
      },
      "overrides": [
        {
          "matcher": { "id": "byName", "options": "connect_timeout" },
          "properties": [
            { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } },
            { "id": "displayName", "value": "жҺЁзҗҶжңҚеҠЎиҝһжҺҘи¶…ж—¶ (Connect Timeout)" }
          ]
        },
        {
          "matcher": { "id": "byName", "options": "read_timeout" },
          "properties": [
            { "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } },
            { "id": "displayName", "value": "жҺЁзҗҶжңҚеҠЎиҜ»еҸ–и¶…ж—¶пјҲжЁЎеһӢеӨ„зҗҶж…ўпјү" }
          ]
        },
        {
          "matcher": { "id": "byName", "options": "connection" },
          "properties": [
            { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } },
            { "id": "displayName", "value": "жҺЁзҗҶжңҚеҠЎиҝһжҺҘеӨұиҙҘпјҲDNS/жӢ’з»қ/зҪ‘з»ңдёӯж–ӯпјү" }
          ]
        },
        {
          "matcher": { "id": "byName", "options": "rate_limited" },
          "properties": [
            { "id": "color", "value": { "mode": "fixed", "fixedColor": "purple" } },
            { "id": "displayName", "value": "жҺЁзҗҶжңҚеҠЎиў«йҷҗжөҒ (429 Too Many Requests)" }
          ]
        },
        {
          "matcher": { "id": "byName", "options": "http_error" },
          "properties": [
            { "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } },
            { "id": "displayName", "value": "жҺЁзҗҶжңҚеҠЎ HTTP й”ҷиҜҜпјҲиҝ”еӣһејӮеёёзҠ¶жҖҒз Ғпјү" }
          ]
        },
        {
          "matcher": { "id": "byName", "options": "unknown" },
          "properties": [
            { "id": "color", "value": { "mode": "fixed", "fixedColor": "text" } },
            { "id": "displayName", "value": "жҺЁзҗҶжңҚеҠЎжңӘзҹҘй”ҷиҜҜ" }
          ]
        }
      ]
    },
    "targets": [
      {
        "expr": "sum by (error_type) (increase(trajproxy_request_infer_errors_total{node=~\"$node\",run_id=~\"$run_id\"}[5m]))",
        "legendFormat": "{{ error_type }}",
        "refId": "A"
      }
    ],
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "sum",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  }
]
