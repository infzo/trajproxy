        "expr": "sum by (run_id) (rate(trajproxy_requests_total{node=~\"$node\",run_id=~\"$run_id\",outcome=~\"error_.+|timeout|stream_partial\"}[5m])) / sum by (run_id) (rate(trajproxy_requests_total{node=~\"$node\",run_id=~\"$run_id\"}[5m])) * 100",
        "legendFormat": "{{ run_id }}",
        "refId": "A"
