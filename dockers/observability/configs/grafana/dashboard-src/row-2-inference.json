[
  {
    "type": "row",
    "title": "Row 2 вҖ” жҺЁзҗҶиҜ·жұӮ",
    "gridPos": {
      "h": 1,
      "w": 24,
      "x": 0,
      "y": 20
    },
    "collapsed": false
  },
  {
    "id": 11,
    "type": "timeseries",
    "title": "жҺЁзҗҶиҜ·жұӮж•° (5min) - жҢүиҝҗиЎҢж ҮиҜҶ",
    "description": "еҗ„дҪңдёҡжҜҸ 5 еҲҶй’ҹиҜ·жұӮж•°йҮҸи¶ӢеҠҝ",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 0,
      "y": 21
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum by (run_id) (increase(trajproxy_requests_total{node=~\"$node\",run_id=~\"$run_id\"}[5m]))",
        "legendFormat": "{{ run_id }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "custom": {
          "fillOpacity": 25,
          "stacking": {
            "mode": "normal"
          },
          "drawStyle": "line"
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "mean"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 12,
    "type": "timeseries",
    "title": "жҺЁзҗҶиҜ·жұӮж•° (5min) - жҢүз»“жһң",
    "description": "жҜҸ 5 еҲҶй’ҹиҜ·жұӮж•°йҮҸжҢүз»“жһңеҲҶзұ»",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 6,
      "y": 21
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum by (outcome) (increase(trajproxy_requests_total{node=~\"$node\",model=~\"$model\"}[5m]))",
        "legendFormat": "{{ outcome }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "custom": {
          "fillOpacity": 20,
          "drawStyle": "line"
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "sum"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 50,
    "type": "timeseries",
    "title": "жҺЁзҗҶиҜ·жұӮз«ҜеҲ°з«ҜиҖ—ж—¶ - жҢүиҝҗиЎҢж ҮиҜҶ (q=$quantile)",
    "description": "з«ҜеҲ°з«ҜиҜ·жұӮе»¶иҝҹ q=$quantile еҲҶдҪҚпјҲеҗ«е…Ё PipelineпјүпјҢжҢү run_id еҲҶз»„",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 0,
      "y": 29
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "histogram_quantile($quantile, sum by (le, run_id) (rate(trajproxy_request_duration_seconds_bucket{node=~\"$node\",model=~\"$model\",run_id=~\"$run_id\"}[5m])))",
        "legendFormat": "{{ run_id }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "s",
        "decimals": 2,
        "custom": {
          "fillOpacity": 5,
          "drawStyle": "line",
          "spanNulls": true
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "mean",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
