  {
    "id": 13,
    "type": "piechart",
    "title": "推理流式与非流式占比(1h)",
    "description": "流式请求占比",
    "gridPos": {
      "h": 8,
      "w": 4,
      "x": 16,
      "y": 21
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum by (stream) (increase(trajproxy_requests_total{node=~\"$node\",model=~\"$model\"}[1h]))",
        "legendFormat": "{{ stream }}",
        "refId": "A",
        "instant": true
      }
    ],
    "options": {
      "pieType": "donut",
      "displayLabels": [
        "percent"
      ],
      "legend": {
        "displayMode": "list",
        "placement": "right"
      }
    }
  },
  {
    "id": 14,
    "type": "piechart",
    "title": "DIRECT vs TITO 模式占比(1h)",
    "description": "直接转发模式（direct）与 Token 模式（tito）请求占比",
    "gridPos": {
      "h": 8,
      "w": 4,
      "x": 20,
      "y": 21
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum by (pipeline_mode) (increase(trajproxy_requests_total{node=~\"$node\",model=~\"$model\"}[1h]))",
        "legendFormat": "{{ pipeline_mode }}",
        "refId": "A",
        "instant": true
      }
    ],
    "options": {
      "pieType": "donut",
      "displayLabels": [
        "percent"
      ],
      "legend": {
        "displayMode": "list",
        "placement": "right"
      }
    }
  },
  {
    "id": 139,
    "type": "timeseries",
    "title": "推理请求失败数量 - 按节点 (5min)",
    "description": "推理请求失败按节点聚合统计：左轴为请求级失败总数，右轴为轨迹写入 DB 失败数",
    "gridPos": {
      "h": 10,
      "w": 8,
      "x": 0,
      "y": 37
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "decimals": 0,
        "custom": {
          "fillOpacity": 10,
          "drawStyle": "line",
          "lineWidth": 2,
          "pointSize": 5,
          "showPoints": "auto",
          "spanNulls": false
        }
      },
      "overrides": [
        {
          "matcher": {
            "id": "byRegexp",
            "options": "^写入.*"
          },
          "properties": [
            {
              "id": "custom.axisPlacement",
              "value": "right"
            },
            {
              "id": "color",
              "value": {
                "mode": "palette-classic"
              }
            }
          ]
        }
      ]
    },
    "targets": [
      {
        "expr": "round(sum by (node) (increase(trajproxy_requests_total{node=~\"$node\",run_id=~\"$run_id\",outcome=~\"error_infer|timeout|stream_partial|error_server\"}[5m])))",
        "legendFormat": "失败: {{ node }}",
        "refId": "A"
      },
      {
        "expr": "round(sum by (node) (increase(trajproxy_trajectory_store_errors_total{node=~\"$node\",run_id=~\"$run_id\"}[5m])))",
        "legendFormat": "写入: {{ node }}",
        "refId": "B"
      }
    ],
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "sum",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
