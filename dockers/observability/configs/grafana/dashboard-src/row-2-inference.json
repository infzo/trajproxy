      "h": 8,
      "w": 6,
      "x": 6,
      "y": 37
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum by (result) (increase(trajproxy_stream_completion_total{node=~\"$node\",model=~\"$model\",run_id=~\"$run_id\"}[$__interval]))",
        "legendFormat": "{{ result }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
