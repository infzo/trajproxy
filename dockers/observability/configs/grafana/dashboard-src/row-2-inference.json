        "decimals": 0,
        "custom": {
          "fillOpacity": 50,
          "drawStyle": "bars",
          "stacking": {
            "mode": "normal"
          }
        }
      },
      "overrides": [
        {
          "matcher": {
            "id": "byName",
            "options": "full"
          },
          "properties": [
            {
              "id": "color",
              "value": {
                "mode": "fixed",
                "fixedColor": "green"
              }
            },
            {
              "id": "displayName",
