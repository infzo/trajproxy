        "expr": "histogram_quantile(0.95, sum by (le, phase) (rate(trajproxy_phase_duration_seconds_bucket{node=~\"$node\",model=~\"$model\"}[5m])))",
        "legendFormat": "{{ phase }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
