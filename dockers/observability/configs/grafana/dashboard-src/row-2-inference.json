[
  {
    "type": "row",
    "title": "Row 2 — 推理请求",
    "gridPos": {
      "h": 1,
      "w": 24,
      "x": 0,
      "y": 20
    },
    "collapsed": false
  },
  {
      "id": 11,
      "type": "timeseries",
      "title": "推理请求数 (5min) - 按运行标识",
      "description": "各作业每 5 分钟请求数量趋势",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 0,
        "y": 21
      },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "round(sum by (run_id) (increase(trajproxy_requests_total{node=~\"$node\",run_id=~\"$run_id\"}[5m])))",
        "legendFormat": "{{ run_id }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "decimals": 0,
        "custom": {
          "fillOpacity": 10,
          "stacking": {
            "mode": "none"
          },
          "drawStyle": "line"
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "mean"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 12,
    "type": "timeseries",
    "title": "推理请求数 (5min) - 按结果",
    "description": "每 5 分钟请求数量按结果分类",
    "gridPos": {
      "h": 8,
      "w": 4,
      "x": 4,
      "y": 21
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "round(sum by (outcome) (increase(trajproxy_requests_total{node=~\"$node\",model=~\"$model\"}[5m])))",
        "legendFormat": "{{ outcome }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "decimals": 0,
        "custom": {
          "fillOpacity": 20,
          "drawStyle": "line"
        }
      },
      "overrides": [
        {
          "matcher": {
            "id": "byName",
            "options": "success"
          },
          "properties": [
            {
              "id": "color",
              "value": {
                "mode": "fixed",
                "fixedColor": "green"
              }
            },
            {
              "id": "displayName",
              "value": "请求成功 (Success)"
            }
          ]
        },
        {
          "matcher": {
            "id": "byName",
            "options": "stream_partial"
          },
          "properties": [
            {
              "id": "color",
              "value": {
                "mode": "fixed",
                "fixedColor": "light-green"
              }
            },
            {
              "id": "displayName",
              "value": "流式传输部分完成 (Stream Partial)"
            }
          ]
        },
        {
          "matcher": {
            "id": "byName",
            "options": "error_client"
          },
          "properties": [
            {
              "id": "color",
              "value": {
                "mode": "fixed",
                "fixedColor": "orange"
              }
            },
            {
              "id": "displayName",
              "value": "客户端-请求不合法 (4xx Client Error)"
            }
          ]
        },
        {
          "matcher": {
            "id": "byName",
            "options": "error_server"
          },
          "properties": [
            {
              "id": "color",
              "value": {
                "mode": "fixed",
                "fixedColor": "dark-red"
              }
            },
            {
              "id": "displayName",
              "value": "内部-服务端错误 (5xx Server Error)"
            }
          ]
        },
        {
          "matcher": {
            "id": "byName",
            "options": "error_rate_limit"
          },
          "properties": [
            {
              "id": "color",
              "value": {
                "mode": "fixed",
                "fixedColor": "purple"
              }
            },
            {
              "id": "displayName",
              "value": "推理-请求被限流 (429 Too Many Requests)"
            }
          ]
        },
        {
          "matcher": {
            "id": "byName",
            "options": "error_infer"
          },
          "properties": [
            {
              "id": "color",
              "value": {
                "mode": "fixed",
                "fixedColor": "blue"
              }
            },
            {
              "id": "displayName",
              "value": "推理-服务异常（连接 / HTTP 错误）"
            }
          ]
        },
        {
          "matcher": {
            "id": "byName",
            "options": "timeout"
          },
          "properties": [
            {
              "id": "color",
              "value": {
                "mode": "fixed",
                "fixedColor": "red"
              }
            },
            {
              "id": "displayName",
              "value": "推理-服务超时 (Timeout)"
            }
          ]
        }
      ]
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "sum"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 142,
    "type": "timeseries",
    "title": "推理内部重试次数 (5min) - 按节点",
    "description": "下游推理服务重试计数，按节点分组，展示每 5 分钟重试次数趋势",
    "gridPos": {
      "h": 8,
      "w": 4,
      "x": 8,
      "y": 21
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum by (node) (increase(trajproxy_infer_retries_total{node=~\"$node\",model=~\"$model\"}[5m]))",
        "legendFormat": "{{ node }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "custom": {
          "fillOpacity": 20,
          "drawStyle": "bars",
          "stacking": {
            "mode": "normal"
          }
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "sum",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 50,
    "type": "timeseries",
    "title": "推理请求端到端耗时 - 按运行标识 (q=$quantile)",
    "description": "端到端请求延迟 q=$quantile 分位（含全 Pipeline），按 run_id 分组",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 0,
      "y": 29
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "histogram_quantile($quantile, sum by (le, run_id) (rate(trajproxy_request_duration_seconds_bucket{node=~\"$node\",model=~\"$model\",run_id=~\"$run_id\"}[5m])))",
        "legendFormat": "{{ run_id }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "s",
        "decimals": 2,
        "custom": {
          "fillOpacity": 5,
          "drawStyle": "line",
          "spanNulls": true
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "mean",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 51,
    "type": "timeseries",
    "title": "推理服务调用耗时 - 按运行标识 (q=$quantile)",
    "description": "对下游推理服务的单次 HTTP 调用耗时 q=$quantile 分位（取 phase=inference），按 run_id 分组",
