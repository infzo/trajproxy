[
  {
    "type": "row",
    "title": "Row 2 — 推理请求",
    "gridPos": {
      "h": 1,
      "w": 24,
      "x": 0,
      "y": 28
    },
    "collapsed": false
  },
  {
    "id": 10,
    "type": "timeseries",
    "title": "推理请求数 (5min) - 按模型",
    "description": "各模型每 5 分钟请求数量趋势",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 0,
      "y": 29
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum by (model) (increase(trajproxy_requests_total{node=~\"$node\",model=~\"$model\"}[5m]))",
        "legendFormat": "{{ model }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "custom": {
          "fillOpacity": 25,
          "stacking": {
            "mode": "normal"
          },
          "drawStyle": "line"
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "mean",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 11,
    "type": "timeseries",
    "title": "推理请求数 (5min) - 按运行标识",
    "description": "各作业每 5 分钟请求数量趋势",
    "gridPos": {
      "h": 8,
