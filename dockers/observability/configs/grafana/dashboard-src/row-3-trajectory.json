[
  {
    "type": "row",
    "title": "Row 3 — 轨迹请求",
    "gridPos": {
      "h": 1,
      "w": 24,
      "x": 0,
      "y": 56
    },
    "collapsed": false
  },
  {
    "id": 121,
    "type": "timeseries",
    "title": "轨迹详情请求数 - 按作业",
    "description": "轨迹详情请求 (trajectory_detail) 增量数，按作业分组",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 0,
      "y": 57
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "round(sum by (run_id) (increase(trajproxy_api_requests_total{node=~\"$node\",route=\"trajectory_detail\",run_id=~\"$run_id\"}[$rate_interval])))",
        "legendFormat": "{{ run_id }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "decimals": 0,
        "custom": {
          "fillOpacity": 0,
          "stacking": {
            "mode": "none"
          },
          "drawStyle": "line"
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "lastNotNull",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 122,
    "type": "timeseries",
    "title": "轨迹详情请求端到端耗时 - 按作业 (q=$quantile)",
    "description": "轨迹详情请求的端到端耗时分位数，按作业分组",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 6,
      "y": 57
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "histogram_quantile($quantile, sum by (le, run_id) (rate(trajproxy_api_request_duration_seconds_bucket{node=~\"$node\",route=\"trajectory_detail\",run_id=~\"$run_id\"}[$rate_interval])))",
        "legendFormat": "{{ run_id }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "s",
        "decimals": 3,
        "custom": {
          "fillOpacity": 0,
          "drawStyle": "line"
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "mean",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 127,
    "type": "timeseries",
    "title": "轨迹平均对话数量 - 按作业",
    "description": "每次轨迹查询返回的 records 条数平均值，按作业分组（基于 trajproxy_trajectory_record_count histogram）",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 12,
      "y": 57
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum by (run_id) (rate(trajproxy_trajectory_record_count_sum{node=~\"$node\",run_id=~\"$run_id\"}[$rate_interval]))\n/\nsum by (run_id) (rate(trajproxy_trajectory_record_count_count{node=~\"$node\",run_id=~\"$run_id\"}[$rate_interval]))",
        "legendFormat": "{{ run_id }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "decimals": 1,
        "custom": {
          "fillOpacity": 0,
          "drawStyle": "line",
          "lineWidth": 2,
          "pointSize": 5,
          "showPoints": "auto",
          "spanNulls": false
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "mean",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 128,
    "type": "timeseries",
    "title": "轨迹请求平均大小 - 按作业",
    "description": "每次轨迹查询返回的响应体平均字节数，按作业分组（基于 trajproxy_trajectory_response_size_bytes histogram）。Grafana bytes 单位自动转换 KB/MB/GB。",
    "gridPos": {
      "h": 8,
      "w": 6,
      "x": 18,
      "y": 57
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum by (run_id) (rate(trajproxy_trajectory_response_size_bytes_sum{node=~\"$node\",run_id=~\"$run_id\"}[$rate_interval]))\n/\nsum by (run_id) (rate(trajproxy_trajectory_response_size_bytes_count{node=~\"$node\",run_id=~\"$run_id\"}[$rate_interval]))",
        "legendFormat": "{{ run_id }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "bytes",
        "decimals": 2,
        "custom": {
          "fillOpacity": 0,
          "drawStyle": "line",
          "lineWidth": 2,
          "pointSize": 5,
          "showPoints": "auto",
          "spanNulls": false
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "mean",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 129,
    "type": "timeseries",
    "title": "轨迹失败请求数 - 按节点",
    "description": "所有非成功轨迹请求按节点聚合统计（含 4xx 客户端错误、5xx 服务端错误等）",
    "gridPos": {
      "h": 10,
      "w": 8,
      "x": 0,
      "y": 65
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "decimals": 0,
        "custom": {
          "fillOpacity": 10,
          "drawStyle": "line",
          "lineWidth": 2,
          "pointSize": 5,
          "showPoints": "auto",
          "spanNulls": false
        }
      }
    },
    "targets": [
      {
        "expr": "round(sum by (node) (increase(trajproxy_api_requests_total{node=~\"$node\",run_id=~\"$run_id\",route=~\"trajectory_list|trajectory_detail|trajectory_legacy\",status_code=~\"[45]..\"}[$rate_interval])))",
        "legendFormat": "错误: {{ node }}",
        "refId": "A"
      }
    ],
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "lastNotNull",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 125,
    "type": "timeseries",
    "title": "轨迹失败请求数 - 按作业",
    "description": "所有非成功轨迹请求按作业聚合统计（含 4xx 客户端错误、5xx 服务端错误等）",
    "gridPos": {
      "h": 10,
      "w": 8,
      "x": 8,
      "y": 65
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "decimals": 0,
        "custom": {
          "fillOpacity": 0,
          "drawStyle": "line",
          "lineWidth": 2,
          "pointSize": 5,
          "showPoints": "auto",
          "spanNulls": false
        }
      }
    },
    "targets": [
      {
        "expr": "round(sum by (run_id) (increase(trajproxy_api_requests_total{node=~\"$node\",run_id=~\"$run_id\",route=~\"trajectory_list|trajectory_detail|trajectory_legacy\",status_code=~\"[45]..\"}[$rate_interval])))",
        "legendFormat": "错误: {{ run_id }}",
        "refId": "A"
      }
    ],
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "lastNotNull",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 126,
    "type": "timeseries",
    "title": "轨迹请求错误细分（请选择作业）",
    "description": "展示所选 作业 的轨迹请求错误按错误类别（database / timeout / serialize_timeout / other）拆分的时间分布。需先在顶端 作业下拉框选择具体作业，选 All 时为所有作业的聚合。",
    "gridPos": {
      "h": 10,
      "w": 8,
      "x": 16,
      "y": 65
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "decimals": 0,
        "custom": {
          "fillOpacity": 50,
          "stacking": {
            "mode": "normal"
          },
          "drawStyle": "bars"
        }
      },
      "overrides": [
        {
          "matcher": {
            "id": "byName",
            "options": "database"
          },
          "properties": [
            {
              "id": "color",
              "value": {
                "mode": "fixed",
                "fixedColor": "red"
              }
            },
            {
              "id": "displayName",
              "value": "DB-数据库异常 (Database Error)"
            }
          ]
        },
        {
          "matcher": {
            "id": "byName",
            "options": "timeout"
          },
          "properties": [
            {
              "id": "color",
              "value": {
                "mode": "fixed",
                "fixedColor": "orange"
              }
            },
            {
              "id": "displayName",
              "value": "DB-查询超时 (Query Timeout)"
            }
          ]
        },
        {
          "matcher": {
            "id": "byName",
            "options": "serialize_timeout"
          },
          "properties": [
            {
              "id": "color",
              "value": {
                "mode": "fixed",
                "fixedColor": "yellow"
              }
            },
            {
              "id": "displayName",
              "value": "内部-序列化超时 (Serialize Timeout)"
            }
          ]
        },
        {
          "matcher": {
            "id": "byName",
            "options": "rate_limit"
          },
          "properties": [
            {
              "id": "color",
              "value": {
                "mode": "fixed",
                "fixedColor": "purple"
              }
            },
            {
              "id": "displayName",
              "value": "内部-请求被限流 (429 Too Many Requests)"
            }
          ]
        },
        {
          "matcher": {
            "id": "byName",
            "options": "other"
          },
          "properties": [
            {
              "id": "color",
              "value": {
                "mode": "fixed",
                "fixedColor": "text"
              }
            },
            {
              "id": "displayName",
              "value": "内部-其他未知错误 (Other)"
            }
          ]
        },
        {
          "matcher": {
            "id": "byName",
            "options": "validation"
          },
          "properties": [
            {
              "id": "color",
              "value": {
                "mode": "fixed",
                "fixedColor": "yellow"
              }
            },
            {
              "id": "displayName",
              "value": "客户端-参数校验失败 (422 Validation)"
            }
          ]
        },
        {
          "matcher": {
            "id": "byName",
            "options": "client_error"
          },
          "properties": [
            {
              "id": "color",
              "value": {
                "mode": "fixed",
                "fixedColor": "orange"
              }
            },
            {
              "id": "displayName",
              "value": "客户端-其他 4xx 错误 (Client Error)"
            }
          ]
        },
        {
          "matcher": {
            "id": "byName",
            "options": "server_error"
          },
          "properties": [
            {
              "id": "color",
              "value": {
                "mode": "fixed",
                "fixedColor": "dark-red"
              }
            },
            {
              "id": "displayName",
              "value": "内部-其他 5xx 错误 (Server Error)"
            }
          ]
        }
      ]
    },
    "targets": [
      {
        "expr": "round(sum by (error_category) (increase(trajproxy_api_errors_total{node=~\"$node\",route=~\"trajectory_list|trajectory_detail|trajectory_legacy\",run_id=~\"$run_id\"}[$__rate_interval])))",
        "legendFormat": "{{ error_category }}",
        "refId": "A"
      }
    ],
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom",
        "calcs": [
          "lastNotNull",
          "max"
        ]
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  }
]
