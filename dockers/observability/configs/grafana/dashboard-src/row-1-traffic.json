[
  {
    "type": "row",
    "title": "Row 1 — 流量概览",
    "gridPos": {
      "h": 1,
      "w": 24,
      "x": 0,
      "y": 10
    },
    "collapsed": false
  },
  {
    "id": 4,
    "type": "stat",
    "title": "推理当前活跃请求",
    "description": "当前正在处理的请求数（实时）",
    "gridPos": {
      "h": 8,
      "w": 4,
      "x": 8,
      "y": 11
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum(trajproxy_active_requests{node=~\"$node\"})",
        "legendFormat": "活跃",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "short"
      }
    }
  },
  {
    "id": 2,
    "type": "stat",
    "title": "推理过去一小时平均端到端耗时",
    "description": "过去 1 小时平均单次请求耗时，从进入 Pipeline 到返回响应（不含信号量排队时间）",
    "gridPos": {
      "h": 8,
      "w": 4,
      "x": 12,
      "y": 11
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum(rate(trajproxy_request_duration_seconds_sum{node=~\"$node\",model=~\"$model\"}[1h])) / sum(rate(trajproxy_request_duration_seconds_count{node=~\"$node\",model=~\"$model\"}[1h]))",
        "legendFormat": "耗时",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "s",
        "decimals": 1,
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {
              "color": "green",
              "value": null
            },
            {
              "color": "yellow",
              "value": 10
            },
            {
              "color": "red",
              "value": 30
            }
          ]
        }
      }
    }
  },
  {
    "id": 3,
    "type": "gauge",
    "title": "推理过去一小时请求成功率",
    "description": "过去 1 小时请求成功率",
    "gridPos": {
      "h": 8,
      "w": 4,
      "x": 16,
      "y": 11
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum(rate(trajproxy_requests_total{node=~\"$node\",model=~\"$model\",outcome=\"success\"}[1h])) / sum(rate(trajproxy_requests_total{node=~\"$node\",model=~\"$model\"}[1h])) * 100",
        "legendFormat": "%",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "percent",
        "min": 0,
        "max": 100,
        "decimals": 1,
        "thresholds": {
          "mode": "absolute",
          "steps": [
            {
              "color": "red",
              "value": null
            },
            {
              "color": "yellow",
              "value": 90
            },
            {
              "color": "green",
              "value": 99
            }
          ]
        }
      }
    }
  },
  {
    "id": 5,
    "type": "stat",
    "title": "推理过去一小时请求总数量",
    "description": "过去 1 小时内所有请求的累计数量",
    "gridPos": {
      "h": 8,
      "w": 4,
      "x": 20,
      "y": 11
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum(increase(trajproxy_requests_total{node=~\"$node\",model=~\"$model\"}[1h]))",
        "legendFormat": "1h",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "short"
      }
    }
  },
  {
    "id": 8,
    "type": "timeseries",
    "title": "推理请求数 (5min)",
    "description": "每 5 分钟推理请求数量",
    "gridPos": {
      "h": 8,
      "w": 8,
      "x": 0,
      "y": 11
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum(increase(trajproxy_requests_total{node=~\"$node\",model=~\"$model\"}[5m]))",
        "legendFormat": "请求数",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "custom": {
          "fillOpacity": 20,
          "drawStyle": "line"
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom"
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 110,
    "type": "timeseries",
    "title": "轨迹列表请求数 (5min)",
    "description": "按 run_id 查询轨迹列表每 5 分钟请求数",
    "gridPos": {
      "h": 8,
      "w": 8,
      "x": 0,
      "y": 19
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum(increase(trajproxy_api_requests_total{node=~\"$node\",route=\"trajectory_list\"}[5m]))",
        "legendFormat": "trajectory_list",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "custom": {
          "fillOpacity": 20,
          "drawStyle": "line"
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom"
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 111,
    "type": "timeseries",
    "title": "轨迹详情请求数 (5min)",
    "description": "按 session_id 查询轨迹详情每 5 分钟请求数",
    "gridPos": {
      "h": 8,
      "w": 8,
      "x": 8,
      "y": 19
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum(increase(trajproxy_api_requests_total{node=~\"$node\",route=\"trajectory_detail\"}[5m]))",
        "legendFormat": "trajectory_detail",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "custom": {
          "fillOpacity": 20,
          "drawStyle": "line"
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom"
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  },
  {
    "id": 115,
    "type": "timeseries",
    "title": "轨迹存储错误",
    "description": "推理后轨迹存储到 DB 失败的次数 by error_type",
    "gridPos": {
      "h": 8,
      "w": 8,
      "x": 16,
      "y": 19
    },
    "datasource": {
      "type": "prometheus",
      "uid": "$datasource"
    },
    "targets": [
      {
        "expr": "sum by (error_type) (increase(trajproxy_trajectory_store_errors_total{node=~\"$node\"}[5m]))",
        "legendFormat": "{{ error_type }}",
        "refId": "A"
      }
    ],
    "fieldConfig": {
      "defaults": {
        "unit": "short",
        "custom": {
          "drawStyle": "bars"
        }
      }
    },
    "options": {
      "legend": {
        "displayMode": "table",
        "placement": "bottom"
      },
      "tooltip": {
        "mode": "multi"
      }
    }
  }
]
