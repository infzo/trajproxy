    {
      "id": 51,
      "type": "timeseries",
      "title": "推理服务调用耗时 - 按运行标识 (q=$quantile)",
      "description": "对下游推理服务的单次 HTTP 调用耗时 q=$quantile 分位（取 phase=inference），按 run_id 分组",
      "gridPos": {
        "h": 8,
