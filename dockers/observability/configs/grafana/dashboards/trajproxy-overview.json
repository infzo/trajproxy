    {
      "id": 35,
      "type": "timeseries",
      "title": "推理并发限流 (429)",
      "description": "Semaphore 超时拒绝速率",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 29
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
