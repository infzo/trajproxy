{
  "uid": "trajproxy-overview",
  "title": "TrajProxy Overview",
  "description": "TrajProxy 可观测性 Dashboard (Level 2) — 概览 / 负载 / 性能 / 错误 / 系统",
  "tags": [
    "trajproxy",
    "observability"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "数据源",
        "refresh": 1
      },
      {
        "name": "node",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "query": "label_values(up{job=\"trajproxy\"}, node)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "label": "节点",
        "allValue": ".*",
        "current": {}
      },
      {
        "name": "model",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "query": "label_values(trajproxy_requests_total, model)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "label": "模型",
        "allValue": ".*",
        "current": {}
      },
      {
        "name": "run_id",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "query": "label_values(trajproxy_requests_total, run_id)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "label": "Run ID",
        "allValue": ".*",
        "current": {}
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "$datasource"
        },
        "query": "label_values(up{job=\"trajproxy\"}, instance)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "label": "实例",
        "allValue": ".*",
        "current": {}
      },
      {
        "name": "quantile",
        "type": "custom",
        "label": "分位数",
        "query": "P50 : 0.5, P95 : 0.95, P99 : 0.99",
        "current": {
          "text": "P95",
          "value": "0.95"
        },
        "options": [
          {
            "text": "P50",
            "value": "0.5",
            "selected": false
          },
          {
            "text": "P95",
            "value": "0.95",
            "selected": true
          },
          {
            "text": "P99",
            "value": "0.99",
            "selected": false
          }
        ],
        "includeAll": false,
        "multi": false,
        "hide": 0,
        "sort": 0
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Row 0 — 全局总览",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 100,
      "type": "piechart",
      "title": "全站请求类型占比 (1h)",
      "description": "各请求类型在过去 1 小时的请求占比",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "sum by (route) (increase(trajproxy_api_requests_total{node=~\"$node\"}[1h]))",
          "legendFormat": "{{ route }}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "pieType": "donut",
        "displayLabels": [
          "percent"
        ],
        "legend": {
          "displayMode": "list",
          "placement": "right"
        }
      }
    },
    {
      "id": 101,
      "type": "timeseries",
      "title": "全站请求数 (5min) - 按请求类型",
      "description": "各请求类型每 5 分钟请求数量趋势",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 4,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "sum by (route) (increase(trajproxy_api_requests_total{node=~\"$node\"}[5m]))",
          "legendFormat": "{{ route }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 25,
            "stacking": {
              "mode": "normal"
            },
            "drawStyle": "line"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 102,
      "type": "timeseries",
      "title": "全站 API 耗时 P95 - 按请求类型",
      "description": "各请求类型 HTTP 耗时 P95",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(trajproxy_api_request_duration_seconds_bucket{node=~\"$node\"}[5m])))",
          "legendFormat": "{{ route }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3,
          "custom": {
            "fillOpacity": 5,
            "drawStyle": "line"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 36,
      "type": "timeseries",
      "title": "模型生命周期事件",
      "description": "register / unregister / 轨迹存储错误",
      "gridPos": {
        "h": 8,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "sum by (action, type) (increase(trajproxy_model_lifecycle_total{node=~\"$node\"}[5m]))",
          "legendFormat": "{{ action }}:{{ type }}",
          "refId": "A"
        },
        {
          "expr": "sum by (model) (rate(trajproxy_trajectory_store_errors_total{node=~\"$node\"}[5m]))",
          "legendFormat": "store_err: {{ model }}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "row",
      "title": "Row 1 — 流量概览",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "collapsed": false
    },
    {
      "id": 4,
      "type": "stat",
      "title": "推理当前活跃请求",
      "description": "当前正在处理的请求数（实时）",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 8,
        "y": 11
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "sum(trajproxy_active_requests{node=~\"$node\"})",
          "legendFormat": "活跃",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "推理过去一小时平均端到端耗时",
      "description": "过去 1 小时平均单次请求耗时，从进入 Pipeline 到返回响应（不含信号量排队时间）",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 12,
        "y": 11
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "sum(rate(trajproxy_request_duration_seconds_sum{node=~\"$node\",model=~\"$model\"}[1h])) / sum(rate(trajproxy_request_duration_seconds_count{node=~\"$node\",model=~\"$model\"}[1h]))",
          "legendFormat": "耗时",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 30
              }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "gauge",
      "title": "推理过去一小时请求成功率",
      "description": "过去 1 小时请求成功率",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 16,
        "y": 11
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "sum(rate(trajproxy_requests_total{node=~\"$node\",model=~\"$model\",outcome=\"success\"}[1h])) / sum(rate(trajproxy_requests_total{node=~\"$node\",model=~\"$model\"}[1h])) * 100",
          "legendFormat": "%",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 90
              },
              {
                "color": "green",
                "value": 99
              }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "推理过去一小时请求总数量",
      "description": "过去 1 小时内所有请求的累计数量",
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 20,
        "y": 11
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "sum(increase(trajproxy_requests_total{node=~\"$node\",model=~\"$model\"}[1h]))",
          "legendFormat": "1h",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "推理请求数 (5min)",
      "description": "每 5 分钟推理请求数量",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 11
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "sum(increase(trajproxy_requests_total{node=~\"$node\",model=~\"$model\"}[5m]))",
          "legendFormat": "请求数",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 20,
            "drawStyle": "line"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 110,
      "type": "timeseries",
      "title": "轨迹列表请求数 (5min)",
      "description": "按 run_id 查询轨迹列表每 5 分钟请求数",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 19
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "sum(increase(trajproxy_api_requests_total{node=~\"$node\",route=\"trajectory_list\"}[5m]))",
          "legendFormat": "trajectory_list",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 20,
