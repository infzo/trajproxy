          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 115,
      "type": "timeseries",
      "title": "轨迹存储错误",
      "description": "推理后轨迹存储到 DB 失败的次数 by error_type",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 19
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "sum by (error_type) (increase(trajproxy_trajectory_store_errors_total{node=~\"$node\"}[5m]))",
          "legendFormat": "{{ error_type }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "type": "row",
      "title": "Row 2 — 推理请求",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 28
      },
      "collapsed": false
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "推理请求数 (5min) - 按模型",
      "description": "各模型每 5 分钟请求数量趋势",
      "gridPos": {
        "h": 8,
