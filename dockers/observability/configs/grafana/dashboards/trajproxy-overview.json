          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 111,
      "type": "timeseries",
      "title": "轨迹详情请求数 (5min)",
      "description": "按 session_id 查询轨迹详情每 5 分钟请求数",
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 19
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$datasource"
      },
      "targets": [
        {
          "expr": "sum(increase(trajproxy_api_requests_total{node=~\"$node\",route=\"trajectory_detail\"}[5m]))",
          "legendFormat": "trajectory_detail",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 20,
