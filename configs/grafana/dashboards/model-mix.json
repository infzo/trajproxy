{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": "1.0.0"},
    {"type": "panel", "id": "piechart", "name": "Pie chart", "version": "1.0.0"}
  ],
  "uid": "trajproxy-model-mix",
  "title": "TrajProxy Model Mix",
  "description": "TrajProxy 模型混合使用监控面板",
  "tags": ["trajproxy", "model"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {"from": "now-6h", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "model",
        "label": "模型",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(traj_proxy_request_total, model)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      },
      {
        "name": "route_type",
        "label": "路由类型",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(traj_proxy_request_total, route_type)",
        "includeAll": true,
        "multi": true,
        "refresh": 2
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Annotations",
        "datasource": "Prometheus",
        "enable": true,
        "iconColor": "red",
        "expr": "changes(process_start_time_seconds{job=\"traj_proxy\"}[1m]) > 0",
        "titleFormat": "服务重启",
        "textFormat": "TrajProxy 服务重启"
      }
    ]
  },
  "panels": [
      {
        "title": "📈 概览",
        "type": "row",
        "gridPos": {"x": 0, "y": 0, "w": 24, "h": 1}
      },
      {
        "id": 1,
        "title": "QPM",
        "type": "stat",
        "datasource": "Prometheus",
        "gridPos": {"x": 0, "y": 1, "w": 6, "h": 3},
        "fieldConfig": {
          "defaults": {
            "unit": "reqpm",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 100},
                {"color": "red", "value": 200}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "value",
          "graphMode": "area",
          "textMode": "auto",
          "orientation": "auto"
        },
        "targets": [
          {"expr": "sum(rate(traj_proxy_request_total{model=~\"$model\", route_type=~\"$route_type\"}[$__rate_interval])) * 60", "legendFormat": "QPM"}
        ]
      },
      {
        "id": 2,
        "title": "活跃模型数",
        "type": "stat",
        "datasource": "Prometheus",
        "gridPos": {"x": 6, "y": 1, "w": 6, "h": 3},
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "blue", "value": null},
                {"color": "green", "value": 5}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "value",
          "graphMode": "none",
          "textMode": "auto"
        },
        "targets": [
          {"expr": "count(count by (model) (rate(traj_proxy_request_total{model=~\"$model\", route_type=~\"$route_type\"}[$__rate_interval]) > 0))", "legendFormat": "活跃模型"}
        ]
      },
      {
        "id": 3,
        "title": "错误率",
        "type": "stat",
        "datasource": "Prometheus",
        "gridPos": {"x": 12, "y": 1, "w": 6, "h": 3},
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 0.01},
                {"color": "red", "value": 0.05}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "background",
          "graphMode": "area",
          "textMode": "auto"
        },
        "targets": [
          {"expr": "sum(rate(traj_proxy_request_failures_total{model=~\"$model\", route_type=~\"$route_type\"}[$__rate_interval])) / sum(rate(traj_proxy_request_total{model=~\"$model\", route_type=~\"$route_type\"}[$__rate_interval]))", "legendFormat": "错误率"}
        ]
      },
      {
        "id": 4,
        "title": "请求延迟 P95",
        "type": "stat",
        "datasource": "Prometheus",
        "gridPos": {"x": 18, "y": 1, "w": 6, "h": 3},
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 5},
                {"color": "red", "value": 15}
              ]
            }
          }
        },
        "options": {
          "reduceOptions": {"calcs": ["lastNotNull"]},
          "colorMode": "value",
          "graphMode": "area",
          "textMode": "auto"
        },
        "targets": [
          {"expr": "histogram_quantile(0.95, sum by (le) (rate(traj_proxy_request_duration_seconds_bucket{model=~\"$model\", route_type=~\"$route_type\"}[$__rate_interval])))", "legendFormat": "P95"}
        ]
      },
      {
        "title": "📊 模型使用统计",
        "type": "row",
        "gridPos": {"x": 0, "y": 4, "w": 24, "h": 1}
      },
      {
        "id": 10,
        "title": "Token 转换比率",
        "type": "timeseries",
        "datasource": "Prometheus",
        "gridPos": {"x": 0, "y": 5, "w": 5, "h": 5},
        "fieldConfig": {
          "defaults": {
            "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "axisCenteredZero": true},
            "unit": "percentunit", "min": -1, "max": 1,
            "color": {"mode": "palette-by-name"}
          },
          "overrides": [
            {"matcher": {"id": "byRegexp", "options": ".*in.*"}, "properties": [{"id": "color", "value": {"mode": "continuous-BlPu"}}]},
            {"matcher": {"id": "byRegexp", "options": ".*out.*"}, "properties": [{"id": "color", "value": {"mode": "continuous-OrPu"}}]}
          ]
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        },
        "targets": [
          {"expr": "sum by (direction, model) (rate(traj_proxy_token_convert_total{direction=\"in\"}[$__rate_interval])) / (sum by (direction, model) (rate(traj_proxy_token_convert_total{direction=\"in\"}[$__rate_interval])) + sum by (direction, model) (rate(traj_proxy_token_convert_total{direction=\"out\"}[$__rate_interval]))) - 0.5", "legendFormat": "{{model}} in"},
          {"expr": "sum by (direction, model) (rate(traj_proxy_token_convert_total{direction=\"out\"}[$__rate_interval])) / (sum by (direction, model) (rate(traj_proxy_token_convert_total{direction=\"in\"}[$__rate_interval])) + sum by (direction, model) (rate(traj_proxy_token_convert_total{direction=\"out\"}[$__rate_interval]))) - 0.5", "legendFormat": "{{model}} out"}
        ]
      },
      {
        "id": 11,
        "title": "Token 流量镜像",
        "type": "timeseries",
        "datasource": "Prometheus",
        "gridPos": {"x": 5, "y": 5, "w": 5, "h": 5},
        "fieldConfig": {
          "defaults": {
            "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "axisCenteredZero": true},
            "unit": "short",
            "color": {"mode": "palette-by-name"}
          },
          "overrides": [
            {"matcher": {"id": "byRegexp", "options": ".*input.*"}, "properties": [{"id": "color", "value": {"mode": "continuous-BlPu"}}]},
            {"matcher": {"id": "byRegexp", "options": ".*output.*"}, "properties": [{"id": "color", "value": {"mode": "continuous-PuRd"}}]}
          ]
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        },
        "targets": [
          {"expr": "sum by (direction, model) (rate(traj_proxy_provider_token_mirror_total{direction=\"input\"}[$__rate_interval]))", "legendFormat": "{{model}} input"},
          {"expr": "-sum by (direction, model) (rate(traj_proxy_provider_token_mirror_total{direction=\"output\"}[$__rate_interval]))", "legendFormat": "{{model}} output"}
        ]
      },
      {
        "id": 15,
        "title": "推理 Pipeline 各阶段耗时",
        "description": "P50 各阶段耗时：total / reason / prefill / decode / convert / overhead。overhead = total - 各阶段之和（虚线）",
        "type": "timeseries",
        "datasource": "Prometheus",
        "gridPos": {"x": 10, "y": 5, "w": 5, "h": 5},
        "fieldConfig": {
          "defaults": {
            "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "axisPlacement": "auto"},
            "unit": "s",
            "color": {"mode": "palette-by-name"}
          },
          "overrides": [
            {"matcher": {"id": "byName", "options": "total"},    "properties": [{"id": "custom.lineWidth", "value": 3}, {"id": "color", "value": {"fixedColor": "#1F60C4", "mode": "fixed"}}]},
            {"matcher": {"id": "byName", "options": "reason"},   "properties": [{"id": "color", "value": {"fixedColor": "#F2CC0C", "mode": "fixed"}}]},
            {"matcher": {"id": "byName", "options": "prefill"},  "properties": [{"id": "color", "value": {"fixedColor": "#FF9830", "mode": "fixed"}}]},
            {"matcher": {"id": "byName", "options": "decode"},   "properties": [{"id": "color", "value": {"fixedColor": "#73BF69", "mode": "fixed"}}]},
            {"matcher": {"id": "byName", "options": "convert"},  "properties": [{"id": "color", "value": {"fixedColor": "#B877D9", "mode": "fixed"}}]},
            {"matcher": {"id": "byName", "options": "overhead"}, "properties": [{"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [10, 10]}}, {"id": "color", "value": {"fixedColor": "#F2495C", "mode": "fixed"}}]}
          ]
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        },
        "targets": [
          {"expr": "histogram_quantile(0.5, sum by (le, stage) (rate(traj_proxy_pipeline_stage_duration_seconds_bucket[$__rate_interval])))", "legendFormat": "{{stage}}"}
        ]
      },
      {
        "id": 13,
        "title": "推理流式与非流式占比",
        "type": "timeseries",
        "datasource": "Prometheus",
        "gridPos": {"x": 15, "y": 5, "w": 5, "h": 5},
        "fieldConfig": {
          "defaults": {
            "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 30, "stacking": {"mode": "percent", "group": "A"}},
            "unit": "percentunit", "min": 0, "max": 1,
            "color": {"mode": "palette-by-name"}
          },
          "overrides": [
            {"matcher": {"id": "byName", "options": "流式"}, "properties": [{"id": "color", "value": {"fixedColor": "blue", "mode": "fixed"}}]},
            {"matcher": {"id": "byName", "options": "非流式"}, "properties": [{"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}]}
          ]
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        },
        "targets": [
          {"expr": "sum(rate(traj_proxy_request_total{route_type=\"inference\", mode=\"stream\"}[$__rate_interval])) / sum(rate(traj_proxy_request_total{route_type=\"inference\"}[$__rate_interval]))", "legendFormat": "流式"},
          {"expr": "sum(rate(traj_proxy_request_total{route_type=\"inference\", mode=\"non_stream\"}[$__rate_interval])) / sum(rate(traj_proxy_request_total{route_type=\"inference\"}[$__rate_interval]))", "legendFormat": "非流式"}
        ]
      },
      {
        "id": 14,
        "title": "错误分布",
        "type": "timeseries",
        "datasource": "Prometheus",
        "gridPos": {"x": 20, "y": 5, "w": 5, "h": 5},
        "fieldConfig": {
          "defaults": {
            "custom": {"drawStyle": "bars", "lineWidth": 0, "fillOpacity": 80, "stacking": {"mode": "normal", "group": "A"}},
            "unit": "short",
            "color": {"mode": "palette-by-name"}
          }
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["sum", "lastNotNull"]},
          "tooltip": {"mode": "multi"}
        },
        "targets": [
          {"expr": "sum by (error_type) (rate(traj_proxy_request_failures_total{route_type=~\"$route_type\"}[$__rate_interval]))", "legendFormat": "{{error_type}}"}
        ]
      },
      {
        "title": "📉 Token 统计",
        "type": "row",
        "gridPos": {"x": 0, "y": 10, "w": 24, "h": 1}
      },
      {
        "id": 20,
        "title": "输入 Token 速率",
        "type": "timeseries",
        "datasource": "Prometheus",
        "gridPos": {"x": 0, "y": 11, "w": 8, "h": 5},
        "fieldConfig": {
          "defaults": {
            "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 20},
            "unit": "tps",
            "color": {"mode": "palette-by-name"}
          }
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        },
        "targets": [
          {"expr": "sum by (model) (rate(traj_proxy_input_tokens_total{model=~\"$model\", route_type=~\"$route_type\"}[$__rate_interval]))", "legendFormat": "{{model}}"}
        ]
      },
      {
        "id": 21,
        "title": "输出 Token 速率",
        "type": "timeseries",
        "datasource": "Prometheus",
        "gridPos": {"x": 8, "y": 11, "w": 8, "h": 5},
        "fieldConfig": {
          "defaults": {
            "custom": {"drawStyle": "line", "lineWidth": 2, "fillOpacity": 20},
            "unit": "tps",
            "color": {"mode": "palette-by-name"}
          }
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"]},
          "tooltip": {"mode": "multi", "sort": "desc"}
        },
        "targets": [
          {"expr": "sum by (model) (rate(traj_proxy_output_tokens_total{model=~\"$model\", route_type=~\"$route_type\"}[$__rate_interval]))", "legendFormat": "{{model}}"}
        ]
      },
      {
        "id": 22,
        "title": "Token 市场份额",
        "type": "piechart",
        "datasource": "Prometheus",
        "gridPos": {"x": 16, "y": 11, "w": 8, "h": 5},
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-by-name"}
          }
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "table", "placement": "right", "values": ["value", "percent"]},
          "pieType": "donut",
          "tooltip": {"mode": "single"}
        },
        "targets": [
          {"expr": "sum by (model) (increase(traj_proxy_input_tokens_total{model=~\"$model\", route_type=~\"$route_type\"}[$__range])) + sum by (model) (increase(traj_proxy_output_tokens_total{model=~\"$model\", route_type=~\"$route_type\"}[$__range]))", "legendFormat": "{{model}}", "instant": true}
        ]
      },
      {
        "title": "🔧 系统状态",
        "type": "row",
        "gridPos": {"x": 0, "y": 16, "w": 24, "h": 1}
      },
      {
        "id": 30,
        "title": "内存使用",
        "type": "timeseries",
        "datasource": "Prometheus",
        "gridPos": {"x": 0, "y": 17, "w": 6, "h": 5},
        "fieldConfig": {
          "defaults": {
            "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "gradientMode": "scheme"},
            "unit": "bytes",
            "color": {"mode": "continuous-BlPu"}
          }
        },
        "options": {
          "legend": {"showLegend": false},
          "tooltip": {"mode": "single"}
        },
        "targets": [
          {"expr": "process_resident_memory_bytes{job=\"traj_proxy\"}", "legendFormat": "RSS"}
        ]
      },
      {
        "id": 31,
        "title": "CPU 使用",
        "type": "timeseries",
        "datasource": "Prometheus",
        "gridPos": {"x": 6, "y": 17, "w": 6, "h": 5},
        "fieldConfig": {
          "defaults": {
            "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 10},
            "unit": "percentunit",
            "color": {"mode": "continuous-OrPu"}
          }
        },
        "options": {
          "legend": {"showLegend": false},
          "tooltip": {"mode": "single"}
        },
        "targets": [
          {"expr": "rate(process_cpu_seconds_total{job=\"traj_proxy\"}[$__rate_interval])", "legendFormat": "CPU"}
        ]
      },
      {
        "id": 32,
        "title": "Goroutines",
        "type": "timeseries",
        "datasource": "Prometheus",
        "gridPos": {"x": 12, "y": 17, "w": 6, "h": 5},
        "fieldConfig": {
          "defaults": {
            "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 10},
            "unit": "short",
            "color": {"mode": "continuous-PuRd"}
          }
        },
        "options": {
          "legend": {"showLegend": false},
          "tooltip": {"mode": "single"}
        },
        "targets": [
          {"expr": "go_goroutines{job=\"traj_proxy\"}", "legendFormat": "Goroutines"}
        ]
      },
      {
        "id": 33,
        "title": "请求 QPS (按模型)",
        "type": "timeseries",
        "datasource": "Prometheus",
        "gridPos": {"x": 18, "y": 17, "w": 6, "h": 5},
        "fieldConfig": {
          "defaults": {
            "custom": {"drawStyle": "bars", "lineWidth": 0, "fillOpacity": 70, "stacking": {"mode": "normal"}},
            "unit": "reqps",
            "color": {"mode": "palette-by-name"}
          }
        },
        "options": {
          "legend": {"showLegend": true, "displayMode": "table", "placement": "bottom", "calcs": ["sum"]},
          "tooltip": {"mode": "multi"}
        },
        "targets": [
          {"expr": "sum by (model) (rate(traj_proxy_request_total{model=~\"$model\", route_type=~\"$route_type\"}[$__rate_interval]))", "legendFormat": "{{model}}"}
        ]
      }
  ]
}
